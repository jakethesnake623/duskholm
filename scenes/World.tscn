; ── Merchants ──────────────────────────────────────────────────────────────────
[node name="MerchantRoom1" parent="." instance=ExtResource("5")]
position = Vector2(100.0, 660.0)
dialogue_lines = PackedStringArray("...fire does not die... it waits...", "I remember warmth. What followed was not peace. It was absence.", "The Hearth called you here. That is not an accident.", "We burned. But we were alive. Can you say the same of this cold?", "Aldren feared what the fire could become. I think he feared the wrong thing.", "Something still breathes beneath the stone. You can feel it.")

[node name="MerchantRoom3" parent="." instance=ExtResource("5")]
position = Vector2(950.0, 1380.0)
dialogue_lines = PackedStringArray("We burned too bright. All things that burn too bright become cinders.", "I have watched them wander for centuries. They are tired. Let them rest.", "The darkness is patient. Perhaps that is a kind of wisdom.", "Aldren tried to protect us with flame. You see what his protection built.", "Peace is not always warmth. Sometimes peace is simply... stillness.", "End the cycle. It is the only mercy left in this place.")

; ── Soul Wells ─────────────────────────────────────────────────────────────────
; The Cradle well — first thing the player encounters. Inner-voice lines play on
; first interaction, hinting at the well's nature and the player's lost memory.
[node name="SoulWellRoom0" parent="." instance=ExtResource("6")]
position = Vector2(-640.0, 640.0)
inner_voice_lines = PackedStringArray("...The dark is familiar. That should worry me more than it does.", "I don't remember arriving here. I don't remember anything before the cold of this floor.", "Something in this basin stirs when I draw near. Old. Patient. As though it has been waiting.", "If I give myself to it... will it hold me when I fall?")
room_id = "room0"
well_name = "The Cradle"

